# Telegram API
BOT_TOKEN=your-telegram-bot-token

# SSH configuration (mail server)
SSH_HOST=your-ssh-server
SSH_PORT=22
SSH_USERNAME=root
SSH_KEY_PATH=/path/to/private/key

# DigitalOcean API
DIGITALOCEAN_TOKEN=your-do-api-token

# Authorization — Telegram user IDs (comma-separated)
AUTHORIZED_MAIL_USERS=123456789
AUTHORIZED_DROPLET_USERS=123456789
AUTHORIZED_K8S_USERS=123456789
AUTHORIZED_STAND_USERS=123456789

# Mail server settings
MAIL_DEFAULT_DOMAIN=example.com
MAIL_DB_USER=root
MAIL_DB_PASSWORD=my-secret-password

# Database (optional, default: ./instances.db)
# DB_PATH=./instances.db

# Notification channel (optional, notifications disabled if not set)
# NOTIFICATION_CHANNEL_ID=-100123456789

# Mattermost bot (optional, MM bot won't start without MM_BOT_TOKEN)
# MM_BOT_TOKEN=your-mm-bot-token
# MM_SERVER_URL=https://mattermost.example.com
# MM_WEBHOOK_PORT=8065
# MM_WEBHOOK_HOST=localhost
# MM_AUTHORIZED_MAIL_USERS=mm-user-id
# MM_AUTHORIZED_DROPLET_USERS=mm-user-id
# MM_AUTHORIZED_K8S_USERS=mm-user-id
# MM_AUTHORIZED_STAND_USERS=mm-user-id
# MM_NOTIFICATION_CHANNEL_ID=channel-id

# Test stands — Gitea Actions in stands-for-connectors
# GITEA_TOKEN needs write access to the stands repo (workflow dispatch).
# Stand features are disabled if GITEA_TOKEN is not set.
# GITEA_TOKEN=your-gitea-api-token
# GITEA_URL=https://git.onlyoffice.com
# STANDS_REPO_OWNER=ONLYOFFICE-DevOps
# STANDS_REPO_NAME=stands-for-connectors
# STAND_DOMAIN=onlyoffice.fun
